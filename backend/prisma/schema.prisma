generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VIEWER

  EDITOR

  ADMIN
}

enum ArticleStatus {
  DRAFT

  SUBMITTED

  IN_REVIEW

  APPROVED

  REJECTED

  PUBLISHED

  ARCHIVED

  DELETED
}

enum ArticleType {
  HOW_TO
  SOP
  FAQ
  TROUBLESHOOTING
  FEATURE_REFERENCE
  RELEASE_NOTES
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  password_hash       String
  role                Role      @default(VIEWER)
  department          String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastFailedLogin     DateTime?
  isActive            Boolean   @default(true)

  // Author relation
  articles Article[] @relation("ArticleAuthor")

  // Reviewer
  reviewedArticles Article[] @relation("ArticleReviewer")

  reviewHistory ReviewHistory[]

  feedbacks    Feedback[]
  auditLogs    AuditLog[]
  chatSessions ChatSession[]
  media        Media[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Category {
  id String @id @default(uuid())

  name        String  @unique
  description String?

  articles  Article[]
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  icon      String?
  sortOrder Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id      String        @id @default(uuid())
  title   String
  slug    String        @unique
  content String
  type    ArticleType   @default(FAQ)
  status  ArticleStatus @default(DRAFT)
  product String?

  // Author
  authorId String
  author   User   @relation("ArticleAuthor", fields: [authorId], references: [id])

  // Reviewer
  reviewerId String?
  reviewer   User?   @relation("ArticleReviewer", fields: [reviewerId], references: [id])

  // Workflow
  reviewComments  String?
  submittedAt     DateTime?
  reviewStartedAt DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  publishedAt     DateTime?
  archivedAt      DateTime?
  deletedAt       DateTime?
  lastStatus      ArticleStatus?

  category      Category          @relation(fields: [categoryId], references: [id])
  categoryId    String
  tags          Tag[]
  feedback      Feedback[]
  versions      ArticleVersion[]
  embedding     ArticleEmbedding?
  medias        Media[]
  reviewHistory ReviewHistory[]

  views       Int      @default(0)
  reviewCount Int      @default(0)
  avgRating   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ArticleVersion {
  id String @id @default(uuid())

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  title String

  content String

  version Int

  createdAt DateTime @default(now())

  @@unique([articleId, version])
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  articles  Article[]
}

model Feedback {
  id        String  @id @default(uuid())
  rating    Int
  comment   String?
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  messageId String?
  createdAt DateTime @default(now())

  @@unique([articleId, userId])
}

model ChatSession {
  id            String        @id @default(uuid())
  title         String?
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  lastMessageAt DateTime      @default(now())
  messages      ChatMessage[]
  totalMessages Int           @default(0)

   isArchived    Boolean       @default(false)
   archivedAt    DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([lastMessageAt])
}

model ChatMessage {
  id        String      @id @default(uuid())
  question  String
  answer    String
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  responseTime Int?
  confidence   Float?
  citations    Json?
  feedback     Boolean? // Was this helpful?
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model ChatAnalytics {
  id String @id @default(uuid())

  sessionId String?
  userId    String?
  question  String

  answerFound       Boolean
  fallbackUsed      Boolean @default(false)
  articlesRetrieved Int
  citationsReturned Int @default(0)
  confidence        Float?

  embeddingTime Int?
  retrievalTime Int?
  llmTime       Int?
  responseTime  Int

  model String

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
  @@index([userId])
  @@index([answerFound])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String

  userId    String?
  user      User? @relation(fields: [userId], references: [id])

  details   Json?
  createdAt DateTime @default(now())
}

model ArticleEmbedding {
  id        String                     @id @default(uuid())
  articleId String                     @unique
  article   Article                    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  content   String // Stores content snapshot for embedding
  embedding Unsupported("vector(384)") // For vector similarity search
  createdAt DateTime                   @default(now())

  @@index([articleId])
}

model SearchLog {
  id          String   @id @default(uuid())
  query       String
  resultCount Int
  userId      String?
  createdAt   DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}

model UnansweredQuestion {
  id         String   @id @default(uuid())
  question   String
  sessionId  String?
  similarity Float?
  reason     String?
  resolved   Boolean  @default(false)
  askedAt    DateTime @default(now())

  @@index([resolved])
  @@index([askedAt])
}

model Media {
  id         String  @id @default(uuid())
  filename   String
  url        String
  type       String
  articleId  String
  article    Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  uploadedBy String
  user       User    @relation(fields: [uploadedBy], references: [id])

  createdAt DateTime @default(now())
}

model ReviewHistory {
  id         String   @id @default(uuid())
  articleId  String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User     @relation(fields: [reviewerId], references: [id])
  action     String
  comments   String?
  createdAt  DateTime @default(now())
}
